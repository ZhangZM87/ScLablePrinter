<UserControl
    x:Class="SCLabelPrinter.Views.EditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SCLabelPrinter.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:SCLabelPrinter.Core.Models;assembly=SCLabelPrinter.Core"
    mc:Ignorable="d">
    <Grid Margin="0,8,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <Border Margin="0,0,12,0" Style="{StaticResource CardBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="工具箱" />
                    <TextBlock
                        Margin="0,6,0,0"
                        Foreground="{StaticResource MutedTextBrush}"
                        Text="按用途分组的插入工具，后续新增元素类型时无需继续扩展固定按钮区。"
                        TextWrapping="Wrap" />
                    <ItemsControl ItemsSource="{Binding ToolboxSections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,14,0,0">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource MutedTextBrush}"
                                        Text="{Binding Title}" />
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button
                                                    Margin="0,8,0,0"
                                                    Padding="10,8"
                                                    HorizontalContentAlignment="Left"
                                                    Command="{Binding Command}"
                                                    Style="{StaticResource SecondaryButtonStyle}">
                                                    <StackPanel>
                                                        <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                                        <TextBlock
                                                            Foreground="{StaticResource MutedTextBrush}"
                                                            Text="{Binding Description}"
                                                            TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock
                        Margin="0,16,0,0"
                        Style="{StaticResource SectionTitleTextStyle}"
                        Text="元素列表" />
                    <ListBox
                        Height="240"
                        ItemsSource="{Binding Elements}"
                        SelectedItem="{Binding SelectedElement}" />
                    <Button
                        Command="{Binding RemoveSelectedElementCommand}"
                        Content="删除选中元素"
                        Style="{StaticResource ActionButtonStyle}" />
                    <Button
                        Margin="0,8,0,0"
                        Command="{Binding ImportExcelToTableCommand}"
                        Content="从 Excel 导入表格"
                        Style="{StaticResource ActionButtonStyle}" />

                    <TextBlock
                        Margin="0,16,0,0"
                        Style="{StaticResource SectionTitleTextStyle}"
                        Text="最近文件" />
                    <ListBox Height="160" ItemsSource="{Binding RecentFiles}" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="2.8*" />
                <RowDefinition Height="12" />
                <RowDefinition Height="1.1*" />
            </Grid.RowDefinitions>

            <Border Margin="0,0,0,0" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <TextBlock
                            DockPanel.Dock="Left"
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="标签预览" />
                        <TextBlock
                            DockPanel.Dock="Right"
                            Foreground="{StaticResource MutedTextBrush}"
                            Text="预览强调布局与内容，不替代最终实物校准。" />
                    </DockPanel>
                    <Border
                        Grid.Row="1"
                        Margin="0,4,0,0"
                        Padding="12"
                        Background="#F4E7D3"
                        BorderBrush="#D7C5AF"
                        BorderThickness="1"
                        CornerRadius="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel
                                Grid.Row="0"
                                Margin="0,0,0,8"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="预览缩放" />
                                <Button
                                    Width="28"
                                    Margin="0,0,8,0"
                                    Command="{Binding ZoomOutCommand}"
                                    Content="-"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                                <TextBlock
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Text="{Binding PreviewZoom, StringFormat={}{0:0.0}x}" />
                                <Button
                                    Width="28"
                                    Margin="0,0,8,0"
                                    Command="{Binding ZoomInCommand}"
                                    Content="+"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                                <Button
                                    Margin="0,0,8,0"
                                    Command="{Binding ResetZoomCommand}"
                                    Content="重置"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                                <Slider
                                    Width="160"
                                    LargeChange="0.5"
                                    Maximum="4"
                                    Minimum="0.5"
                                    SmallChange="0.1"
                                    Value="{Binding PreviewZoom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <ScrollViewer
                                Grid.Row="1"
                                CanContentScroll="False"
                                HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto">
                                <controls:LabelCanvas
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    ElementDragStartedCommand="{Binding BeginSelectedElementMoveCommand}"
                                    ElementMovedCommand="{Binding MoveSelectedElementCommand}"
                                    ElementSelectedCommand="{Binding SelectElementByIdCommand}"
                                    SelectedElementId="{Binding SelectedElementId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    SnapsToDevicePixels="True"
                                    TableCellContextMenuCommand="{Binding TableCellContextMenuCommand}"
                                    TableCellInnerElementMovedCommand="{Binding TableCellInnerElementMoveCommand}"
                                    TableCellResizeCommand="{Binding TableCellResizeCommand}"
                                    MultiElementMovedCommand="{Binding MultiElementMovedCommand}"
                                    Template="{Binding PreviewTemplate}"
                                    ZoomFactor="{Binding PreviewZoom}" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter
                Grid.Row="1"
                Height="12"
                HorizontalAlignment="Stretch"
                Background="#D8CBB7" />

            <Border
                Grid.Row="2"
                Margin="0,0,0,0"
                Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="TSPL 预览" />
                    <TextBox
                        Grid.Row="1"
                        AcceptsReturn="True"
                        FontFamily="Cascadia Mono"
                        FontSize="13"
                        HorizontalScrollBarVisibility="Auto"
                        IsReadOnly="True"
                        Text="{Binding TsplPreview}"
                        VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Border>
        </Grid>

        <Border
            Grid.Column="2"
            Margin="0,0,0,0"
            Style="{StaticResource CardBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="标签设置" />
                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="宽度 (mm)" />
                    <TextBox Text="{Binding LabelWidth, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="高度 (mm)" />
                    <TextBox Text="{Binding LabelHeight, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="间距 (mm)" />
                    <TextBox Text="{Binding LabelGap, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="打印浓度" />
                    <TextBox Text="{Binding Density, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock
                        Margin="0,16,0,0"
                        Style="{StaticResource SectionTitleTextStyle}"
                        Text="元素属性" />
                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="位置 X" />
                    <TextBox Text="{Binding ElementX, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="位置 Y" />
                    <TextBox Text="{Binding ElementY, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="旋转角度" />
                    <TextBox Text="{Binding ElementRotation, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock
                        Margin="0,10,0,0"
                        Style="{StaticResource CaptionTextStyle}"
                        Text="类型专属属性" />
                    <ContentControl Content="{Binding SelectedElement}">
                        <ContentControl.Resources>
                            <DataTemplate DataType="{x:Type models:TextElement}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="文本内容" />
                                    <TextBox Text="{Binding DataContext.SelectedTextContent, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="字体编号" />
                                    <TextBox Text="{Binding DataContext.SelectedFont, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="字体大小 (dot，0=默认)" />
                                    <TextBox Text="{Binding DataContext.SelectedFontSizeDots, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="水平缩放" />
                                    <TextBox Text="{Binding DataContext.SelectedTextXScale, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="垂直缩放" />
                                    <TextBox Text="{Binding DataContext.SelectedTextYScale, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,8,0,0" Style="{StaticResource CaptionTextStyle}" Text="占位符（留空=直接输出内容）" />
                                    <TextBox Text="{Binding DataContext.SelectedPlaceholder, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type models:BarcodeElement}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="条码内容" />
                                    <TextBox Text="{Binding DataContext.SelectedBarcodeContent, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="条码类型" />
                                    <ComboBox SelectedValue="{Binding DataContext.SelectedBarcodeType, RelativeSource={RelativeSource AncestorType=UserControl}}" SelectedValuePath="Tag">
                                        <ComboBoxItem Content="Code39" Tag="{x:Static models:BarcodeType.Code39}" />
                                        <ComboBoxItem Content="Code128" Tag="{x:Static models:BarcodeType.Code128}" />
                                        <ComboBoxItem Content="Ean13" Tag="{x:Static models:BarcodeType.Ean13}" />
                                    </ComboBox>
                                    <CheckBox Content="显示条码文本" IsChecked="{Binding DataContext.SelectedBarcodeReadable, RelativeSource={RelativeSource AncestorType=UserControl}}" Margin="0,4,0,4" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="条码高度" />
                                    <TextBox Text="{Binding DataContext.SelectedBarcodeHeight, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="窄线宽" />
                                    <TextBox Text="{Binding DataContext.SelectedBarcodeNarrow, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="宽线宽" />
                                    <TextBox Text="{Binding DataContext.SelectedBarcodeWide, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,8,0,0" Style="{StaticResource CaptionTextStyle}" Text="占位符" />
                                    <TextBox Text="{Binding DataContext.SelectedPlaceholder, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type models:QrCodeElement}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="二维码内容" />
                                    <TextBox Text="{Binding DataContext.SelectedQrContent, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="纠错级别" />
                                    <TextBox Text="{Binding DataContext.SelectedQrErrorCorrectionLevel, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="单元大小" />
                                    <TextBox Text="{Binding DataContext.SelectedQrCellWidth, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,8,0,0" Style="{StaticResource CaptionTextStyle}" Text="占位符" />
                                    <TextBox Text="{Binding DataContext.SelectedPlaceholder, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type models:BoxElement}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="终点 X" />
                                    <TextBox Text="{Binding DataContext.SelectedBoxEndX, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="终点 Y" />
                                    <TextBox Text="{Binding DataContext.SelectedBoxEndY, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="线宽" />
                                    <TextBox Text="{Binding DataContext.SelectedBoxThickness, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type models:LineElement}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="宽度" />
                                    <TextBox Text="{Binding DataContext.SelectedLineWidth, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="高度" />
                                    <TextBox Text="{Binding DataContext.SelectedLineHeight, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="线条样式" />
                                    <ComboBox SelectedValue="{Binding DataContext.SelectedLineStyle, RelativeSource={RelativeSource AncestorType=UserControl}}" SelectedValuePath="Tag">
                                        <ComboBoxItem Content="实线" Tag="{x:Static models:TableLineStyle.Solid}" />
                                        <ComboBoxItem Content="虚线" Tag="{x:Static models:TableLineStyle.Dashed}" />
                                        <ComboBoxItem Content="点线" Tag="{x:Static models:TableLineStyle.Dotted}" />
                                    </ComboBox>
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="虚线段长" />
                                    <TextBox Text="{Binding DataContext.SelectedLineDashLength, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="间隔长度" />
                                    <TextBox Text="{Binding DataContext.SelectedLineGapLength, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type models:EraseElement}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="宽度" />
                                    <TextBox Text="{Binding DataContext.SelectedEraseWidth, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="高度" />
                                    <TextBox Text="{Binding DataContext.SelectedEraseHeight, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type models:TableElement}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="行高" />
                                    <TextBox Text="{Binding DataContext.SelectedTableRowHeight, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="列宽 A" />
                                    <TextBox Text="{Binding DataContext.SelectedTableColumnWidthA, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="列宽 B" />
                                    <TextBox Text="{Binding DataContext.SelectedTableColumnWidthB, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="整体宽度" />
                                    <TextBox Text="{Binding DataContext.SelectedTableTotalWidth, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="整体高度" />
                                    <TextBox Text="{Binding DataContext.SelectedTableTotalHeight, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="线条样式（边框+网格）" />
                                    <ComboBox SelectedValue="{Binding DataContext.SelectedTableBorderStyle, RelativeSource={RelativeSource AncestorType=UserControl}}" SelectedValuePath="Tag">
                                        <ComboBoxItem Content="实线" Tag="{x:Static models:TableLineStyle.Solid}" />
                                        <ComboBoxItem Content="虚线" Tag="{x:Static models:TableLineStyle.Dashed}" />
                                        <ComboBoxItem Content="点线" Tag="{x:Static models:TableLineStyle.Dotted}" />
                                    </ComboBox>

                                    <Button
                                        Margin="0,10,0,0"
                                        Command="{Binding DataContext.OpenSelectedTableSpreadsheetEditorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Content="打开电子表格编辑器"
                                        Style="{StaticResource SecondaryButtonStyle}" />

                                    <TextBlock
                                        Margin="0,8,0,0"
                                        Foreground="{StaticResource MutedTextBrush}"
                                        Text="复杂表格请在电子表格编辑器中直接编辑单元格与行列结构。"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ContentControl.Resources>
                    </ContentControl>

                    <Button
                        Command="{Binding ApplySelectedElementChangesCommand}"
                        Content="应用属性更改"
                        Style="{StaticResource ActionButtonStyle}" />
                    <WrapPanel Margin="0,10,0,0">
                        <Button
                            Command="{Binding UndoCommand}"
                            Content="撤销"
                            Style="{StaticResource SecondaryButtonStyle}" />
                        <Button
                            Command="{Binding RedoCommand}"
                            Content="重做"
                            Style="{StaticResource SecondaryButtonStyle}" />
                        <Button
                            Command="{Binding SaveTemplateAsCommand}"
                            Content="另存为"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    </WrapPanel>
                    <Button
                        Margin="0,8,0,0"
                        Command="{Binding ExportTsplTemplateCommand}"
                        Content="导出 TSPL 模板"
                        Style="{StaticResource ActionButtonStyle}" />

                    <TextBlock
                        Margin="0,12,0,0"
                        Foreground="{StaticResource MutedTextBrush}"
                        Text="{Binding EditorHint}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>