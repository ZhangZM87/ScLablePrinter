<Window
    x:Class="SCLabelPrinter.Views.TableCellEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:SCLabelPrinter.Core.Models;assembly=SCLabelPrinter.Core"
    Title="编辑表格单元格"
    Width="440"
    MaxHeight="560"
    Background="#FFF6F7F9"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Border
        Padding="18"
        Background="White"
        BorderBrush="#FFCACDD4"
        BorderThickness="1"
        CornerRadius="12">
        <ScrollViewer
            CanContentScroll="True"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="#FF22272E"
                    Text="单元格内容" />

                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                    <TextBlock FontWeight="SemiBold" Text="内容类型" />
                    <ComboBox
                        Margin="0,6,0,0"
                        SelectedValue="{Binding ContentType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        SelectedValuePath="Tag">
                        <ComboBoxItem Content="文本" Tag="{x:Static models:TableCellContentType.Text}" />
                        <ComboBoxItem Content="条码" Tag="{x:Static models:TableCellContentType.Barcode}" />
                        <ComboBoxItem Content="二维码" Tag="{x:Static models:TableCellContentType.QrCode}" />
                    </ComboBox>
                </StackPanel>

                <Border
                    Grid.Row="2"
                    Margin="0,12,0,0"
                    Padding="12"
                    Background="#FFF7F8FB"
                    BorderBrush="#FFE2E5EB"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="显示内容" />
                        <TextBox
                            Height="28"
                            Margin="0,8,0,0"
                            Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="3" Margin="0,12,0,0">
                    <Border
                        Padding="12"
                        Background="#FFF7F8FB"
                        BorderBrush="#FFE2E5EB"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="条码设置" />
                            <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                <TextBlock
                                    Width="72"
                                    VerticalAlignment="Center"
                                    Text="类型" />
                                <ComboBox
                                    Width="220"
                                    SelectedValue="{Binding BarcodeType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    SelectedValuePath="Tag">
                                    <ComboBoxItem Content="Code39" Tag="{x:Static models:BarcodeType.Code39}" />
                                    <ComboBoxItem Content="Code128" Tag="{x:Static models:BarcodeType.Code128}" />
                                    <ComboBoxItem Content="Ean13" Tag="{x:Static models:BarcodeType.Ean13}" />
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border
                        Margin="0,10,0,0"
                        Padding="12"
                        Background="#FFF7F8FB"
                        BorderBrush="#FFE2E5EB"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="二维码设置" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="二维码大小" />
                                    <TextBox
                                        Width="82"
                                        Margin="0,6,0,0"
                                        Text="{Binding QrCellWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="12,0,0,0">
                                    <TextBlock Text="纠错级别" />
                                    <TextBox
                                        Width="82"
                                        Margin="0,6,0,0"
                                        Text="{Binding QrErrorCorrectionLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Margin="0,12,0,0">
                                    <TextBlock Text="二维码模式" />
                                    <TextBox
                                        Width="82"
                                        Margin="0,6,0,0"
                                        Text="{Binding QrMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel
                    Grid.Row="4"
                    Margin="0,18,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        Width="90"
                        Click="CancelButton_Click"
                        Content="取消" />
                    <Button
                        Width="90"
                        Click="OkButton_Click"
                        Content="确定" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Window>
