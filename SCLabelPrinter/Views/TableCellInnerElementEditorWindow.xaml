<Window
    x:Class="SCLabelPrinter.Views.TableCellInnerElementEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:SCLabelPrinter.Core.Models;assembly=SCLabelPrinter.Core"
    Title="编辑单元格内部元素"
    Width="640"
    Height="500"
    Background="#FFF6F7F9"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Border
        Padding="18"
        Background="White"
        BorderBrush="#FFCACDD4"
        BorderThickness="1"
        CornerRadius="12">
        <DockPanel>
            <TextBlock
                FontSize="16"
                FontWeight="Bold"
                Foreground="#FF22272E"
                Text="单元格内部元素" />

            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                        <Button
                            Margin="0,0,8,0"
                            Padding="8,4"
                            Content="添加文本"
                            Command="{Binding AddTextElementCommand}" />
                        <Button
                            Margin="0,0,8,0"
                            Padding="8,4"
                            Content="添加条码"
                            Command="{Binding AddBarcodeElementCommand}" />
                        <Button
                            Padding="8,4"
                            Content="添加二维码"
                            Command="{Binding AddQrCodeElementCommand}" />
                    </StackPanel>

                    <ListBox
                        ItemsSource="{Binding InnerElements}"
                        SelectedItem="{Binding SelectedInnerElement, Mode=TwoWay}"
                        DisplayMemberPath="ToString"
                        MinHeight="300"
                        BorderBrush="#FFE2E5EB"
                        BorderThickness="1"
                        Background="#FFF7F8FB" />

                    <Button
                        Margin="0,12,0,0"
                        Padding="8,6"
                        Content="删除选中元素"
                        Command="{Binding RemoveSelectedInnerElementCommand}" />
                </StackPanel>

                <Border Grid.Column="2"
                        Padding="12"
                        Background="#FFF7F8FB"
                        BorderBrush="#FFE2E5EB"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="当前元素属性" />
                        <TextBlock Margin="0,12,0,0" Text="内容" />
                        <TextBox
                            Text="{Binding SelectedContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Margin="0,4,0,0"
                            Height="26" />

                        <UniformGrid Columns="2" Margin="0,12,0,0" HorizontalAlignment="Stretch">
                            <StackPanel>
                                <TextBlock Text="X" />
                                <TextBox Text="{Binding SelectedX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="26" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Y" />
                                <TextBox Text="{Binding SelectedY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="26" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="宽度" />
                                <TextBox Text="{Binding SelectedWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="26" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="高度" />
                                <TextBox Text="{Binding SelectedHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="26" />
                            </StackPanel>
                        </UniformGrid>

                        <Border Margin="0,12,0,0" Padding="10" Background="WhiteSmoke" CornerRadius="6">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="条码设置" />
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Left">
                                    <TextBlock Width="80" VerticalAlignment="Center" Text="类型" />
                                    <ComboBox
                                        Width="180"
                                        SelectedValue="{Binding SelectedBarcodeType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        SelectedValuePath="Tag">
                                        <ComboBoxItem Content="Code39" Tag="{x:Static models:BarcodeType.Code39}" />
                                        <ComboBoxItem Content="Code128" Tag="{x:Static models:BarcodeType.Code128}" />
                                        <ComboBoxItem Content="Ean13" Tag="{x:Static models:BarcodeType.Ean13}" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Left">
                                    <CheckBox Content="可读" IsChecked="{Binding SelectedBarcodeReadable, Mode=TwoWay}" />
                                </StackPanel>
                                <UniformGrid Columns="2" Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="窄条宽度" />
                                        <TextBox Text="{Binding SelectedBarcodeNarrow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="26" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="宽条宽度" />
                                        <TextBox Text="{Binding SelectedBarcodeWide, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="26" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,0,0" Padding="10" Background="WhiteSmoke" CornerRadius="6">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="二维码设置" />
                                <UniformGrid Columns="3" Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="大小" />
                                        <TextBox Text="{Binding SelectedQrCellWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="26" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="纠错级别" />
                                        <TextBox Text="{Binding SelectedQrErrorCorrectionLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="26" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="模式" />
                                        <TextBox Text="{Binding SelectedQrMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="26" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button
                    Width="90"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"
                    Content="取消" />
                <Button
                    Width="90"
                    Content="确定"
                    Click="OkButton_Click" />
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
