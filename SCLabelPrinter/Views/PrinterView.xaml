<UserControl
    x:Class="SCLabelPrinter.Views.PrinterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Margin="0,12,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.15*" />
            <ColumnDefinition Width="1.85*" />
        </Grid.ColumnDefinitions>

        <Border
            Margin="0,0,14,0"
            CornerRadius="3"
            Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Style="{StaticResource SectionTitleTextStyle}"
                        Text="可用设备"
                        VerticalAlignment="Center" />
                    <Button
                        Grid.Column="1"
                        Command="{Binding ScanCommand}"
                        Content="重新扫描"
                        Style="{StaticResource SecondaryButtonStyle}" />
                </Grid>

                <ListBox
                    Grid.Row="1"
                    MinHeight="260"
                    FontSize="14"
                    ItemsSource="{Binding Printers}"
                    SelectedItem="{Binding SelectedPrinter}" />
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="连接状态" />
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="当前状态" />
                        <TextBlock
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="{Binding CurrentStatusText}" />
                        <TextBlock
                            Margin="0,8,0,0"
                            Style="{StaticResource CaptionTextStyle}"
                            Text="设备型号" />
                        <TextBlock FontSize="18" Text="{Binding CurrentModelText}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Top">
                        <Button Command="{Binding ConnectCommand}" Content="连接" />
                        <Button
                            Command="{Binding DisconnectCommand}"
                            Content="断开"
                            Style="{StaticResource SecondaryButtonStyle}" />
                        <Button
                            Command="{Binding QueryStatusCommand}"
                            Content="查询状态"
                            Style="{StaticResource SecondaryButtonStyle}" />
                        <Button
                            Command="{Binding QueryModelCommand}"
                            Content="查询型号"
                            Style="{StaticResource SecondaryButtonStyle}" />
                        <Button
                            Margin="0,12,0,0"
                            Command="{Binding CalibrateGapCommand}"
                            Content="校正纸张"
                            Style="{StaticResource SecondaryButtonStyle}" />
                        <TextBlock
                            Margin="0,8,0,0"
                            Foreground="Green"
                            Text="{Binding CalibrationResult}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="当前选中设备" />
                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="显示名称" />
                    <TextBlock FontSize="16" Text="{Binding SelectedPrinter.DisplayName, TargetNullValue=尚未选择打印机}" />
                    <TextBlock
                        Margin="0,10,0,0"
                        Style="{StaticResource CaptionTextStyle}"
                        Text="设备路径" />
                    <TextBlock Text="{Binding SelectedPrinter.DevicePath, TargetNullValue=-}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border
                Grid.Row="2"
                Margin="0,0,0,0"
                Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="使用说明" />
                    <TextBlock
                        Foreground="{StaticResource MutedTextBrush}"
                        Text="1. 点击重新扫描发现 USB 打印机。&#x0a;2. 选中设备后执行连接。&#x0a;3. 成功连接后可查询状态、型号，并供编辑器或快速打印页面复用。"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>