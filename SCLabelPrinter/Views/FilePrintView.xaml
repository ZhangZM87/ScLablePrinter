<UserControl
    x:Class="SCLabelPrinter.Views.FilePrintView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="clr-namespace:SCLabelPrinter.Controls"
    mc:Ignorable="d">
    <Grid Margin="0,12,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.65*" />
            <ColumnDefinition Width="1.1*" />
        </Grid.ColumnDefinitions>

        <Border Margin="0,0,14,0" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="直接打印文件" />
                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="请选择要发送到打印机的文件" />

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        Grid.Column="0"
                        MinWidth="0"
                        VerticalAlignment="Center"
                        VerticalContentAlignment="Center"
                        Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        Grid.Column="1"
                        MinHeight="34"
                        Margin="5,0,7,0"
                        VerticalAlignment="Top"
                        Command="{Binding BrowseFileCommand}"
                        Content="浏览"
                        Style="{StaticResource SecondaryButtonStyle}" />
                </Grid>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Style="{StaticResource CaptionTextStyle}"
                        Text="打印份数" />
                    <TextBox
                        Grid.Column="1"
                        Width="120"
                        Margin="16,0,0,0"
                        VerticalContentAlignment="Center"
                        Text="{Binding Copies, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <Button
                    Command="{Binding PrintCommand}"
                    Content="发送到打印机"
                    Style="{StaticResource ActionButtonStyle}" />

                <TextBlock
                    Margin="0,22,0,8"
                    Style="{StaticResource CaptionTextStyle}"
                    Text="文件预览" />
                <Border
                    Padding="10"
                    Background="#FFF7F8FB"
                    BorderBrush="#E7E0D7"
                    BorderThickness="1"
                    CornerRadius="8"
                    MinHeight="260"
                    Margin="0,0,0,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="220" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <controls:LabelCanvas
                            Grid.Row="0"
                            Template="{Binding FilePreviewTemplate}"
                            MinHeight="220"
                            SnapsToDevicePixels="True" />

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <TextBox
                                Text="{Binding FilePreview}"
                                TextWrapping="Wrap"
                                IsReadOnly="True"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource MutedTextBrush}"
                                AcceptsReturn="True"
                                MinHeight="80" />
                        </ScrollViewer>
                    </Grid>
                </Border>

                <TextBlock
                    Margin="0,0,0,8"
                    Style="{StaticResource CaptionTextStyle}"
                    Text="支持格式" />
                <Border
                    Padding="14"
                    Background="#FFF7F8FB"
                    BorderBrush="#E7E0D7"
                    BorderThickness="1"
                    CornerRadius="8">
                    <TextBlock
                        Foreground="{StaticResource MutedTextBrush}"
                        LineHeight="22"
                        Text=".sclabel 会先生成 TSPL 指令；.txt 按 TSPL 文本发送；.prn / .bin 直接按二进制发送。"
                        TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </Border>

        <Border
            Grid.Column="1"
            VerticalAlignment="Top"
            Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="发送状态" />
                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="当前打印任务摘要" />
                <Border
                    Margin="0,0,0,16"
                    Padding="14"
                    Background="#FFF7F8FB"
                    BorderBrush="#E7E0D7"
                    BorderThickness="1"
                    CornerRadius="8">
                    <TextBlock
                        Foreground="{StaticResource MutedTextBrush}"
                        LineHeight="22"
                        Text="{Binding PayloadSummary}"
                        TextWrapping="Wrap" />
                </Border>

                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="打印进度" />
                <Border
                    Padding="14"
                    Background="#FFF7F8FB"
                    BorderBrush="#E7E0D7"
                    BorderThickness="1"
                    CornerRadius="8">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="{Binding ProgressMessage}" />
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>