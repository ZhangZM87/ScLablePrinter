<Window x:Class="SCLabelPrinter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:SCLabelPrinter.Views"
        mc:Ignorable="d"
        Title="SC Label Printer"
        Width="1500"
        Height="920"
        MinWidth="1260"
        MinHeight="760"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Border DockPanel.Dock="Top"
                Margin="16,16,16,12"
                Padding="22"
                Background="#FFF9F0"
                BorderBrush="#D6C8B5"
                BorderThickness="1"
                CornerRadius="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontFamily="Bahnschrift"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Text="SC Label Printer" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="赛创标签打印机管理软件，支持设备管理、模板编辑、文件直打。" />
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                    <Button Command="{Binding Printer.ScanCommand}" Content="扫描设备" />
                    <Button Command="{Binding Printer.ConnectCommand}" Content="连接打印机" />
                    <Button Command="{Binding Printer.QueryStatusCommand}" Content="查询状态" />
                    <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding Editor.NewTemplateCommand}" Content="新建模板" />
                    <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding Editor.OpenTemplateCommand}" Content="打开模板" />
                    <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding Editor.SaveTemplateCommand}" Content="保存模板" />
                    <Button Command="{Binding Editor.PrintTemplateCommand}" Content="打印当前模板" />
                </WrapPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Margin="16,0,16,16"
                Padding="16,10"
                Background="#FFF9F0"
                BorderBrush="#D6C8B5"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <Ellipse Width="14"
                         Height="14"
                         Margin="0,0,12,0"
                         VerticalAlignment="Center"
                         Fill="{Binding Printer.CurrentState, Converter={StaticResource StatusToBrushConverter}}" />
                <TextBlock Grid.Column="1" Text="{Binding Status.PrinterMessage}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding Status.DocumentMessage}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="3" Text="{Binding Status.ActivityMessage}" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <TabControl Margin="16,0,16,0">
            <TabItem Header="打印机管理">
                <views:PrinterView DataContext="{Binding Printer}" />
            </TabItem>
            <TabItem Header="标签编辑器">
                <views:EditorView DataContext="{Binding Editor}" />
            </TabItem>
            <TabItem Header="快速打印">
                <views:FilePrintView DataContext="{Binding FilePrint}" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
